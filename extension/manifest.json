{
  "manifest_version": 3,
  "name": "FixOnce - AI Vision",
  "version": "3.0.0",
  "description": "AI Memory Layer + Visual Context. Capture errors, select elements, let AI see what you see.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["injected.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["element-picker.js"],
      "world": "MAIN",
      "run_at": "document_end"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js", "picker-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
